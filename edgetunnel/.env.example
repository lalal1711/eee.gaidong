# ============================
# edgetunnel 环境变量配置模板
# 复制此文件为 .env 并按需修改
# ============================

# [必需] 管理员后台密码
ADMIN=your_secure_password_here

# [可选] 订阅路径密钥，访问 /KEY 获取节点
KEY=勿动此默认密钥，有需求请自行通过添加变量KEY进行修改

# [可选] 强制固定 UUID (UUIDv4 格式)
# UUID=90cd4a77-141a-43c9-991b-08263cfe9c10

# [可选] 全局自定义反代 IP
# PROXYIP=proxyip.example.com:443

# [可选] 默认主页伪装地址 (URL 或 1101)
# URL=https://example.com

# [可选] 强制走 SOCKS5 的域名列表 (* 为全局，逗号分隔)
# GO2SOCKS5=blog.example.com,*.ip.cn,*google.com

# [可选] 开发者模式 (1=true)
# DEBUG=1

# [可选] 关闭日志记录 (1=true)
# OFF_LOG=1

# [可选] 优选订阅生成器 (1=true)
# BEST_SUB=1

# [可选] 预加载竞速拨号 (1=true)
# PRELOAD_RACE_DIAL=1

# [可选] 主机名列表 (逗号分隔)
# HOST=example.com,sub.example.com
